{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Yumi",
  "theme": "maple",
  "fonts": {
    "family": "JetBrains Mono",
    "heading": {
      "family": "Black Ops One"
    },
    "body": {
      "family": "JetBrains Mono"
    },
    "mono": {
      "family": "JetBrains Mono"
    }
  },
  "styling": {
    "css": ["globals.css"]
  },
  "logo": {
    "dark": "/images/yumi-nav.png",
    "light": "/images/yumi-nav.png"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#22c55e",
    "light": "#ffffff",
    "dark": "#0d1117"
  },
  "anchors": [
    {
      "name": "GitHub",
      "icon": "github",
      "url": "https://github.com/CodeNeuron58/Yumi"
    },
    {
      "name": "Discord",
      "icon": "discord",
      "url": "https://discord.gg/YOUR_DISCORD_INVITE"
    }
  ],
  "navigation": {
